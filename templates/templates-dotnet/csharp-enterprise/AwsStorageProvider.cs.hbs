using System.IO;
using Amazon.S3;
using Amazon.S3.Model;

namespace {{ns}}.Infrastructure.Cloud;

/// <summary>Amazon S3 implementation of ICloudStorageProvider. Bucket name comes from configuration key "CloudStorage:Bucket".</summary>
public class AwsStorageProvider : {{ns}}.Application.Common.Interfaces.ICloudStorageProvider
{
    private readonly IAmazonS3 _client;
    private readonly string _bucket;

    public AwsStorageProvider(IAmazonS3 client, IConfiguration configuration)
    {
        _client = client;
        _bucket = configuration["CloudStorage:Bucket"] ?? throw new InvalidOperationException("CloudStorage:Bucket is not configured");
    }

    public async Task UploadAsync(string key, Stream content, CancellationToken cancellationToken = default)
    {
        await _client.PutObjectAsync(new PutObjectRequest { BucketName = _bucket, Key = key, InputStream = content }, cancellationToken);
    }

    public async Task<Stream> DownloadAsync(string key, CancellationToken cancellationToken = default)
    {
        var response = await _client.GetObjectAsync(_bucket, key, cancellationToken);
        return response.ResponseStream;
    }

    public async Task DeleteAsync(string key, CancellationToken cancellationToken = default)
    {
        await _client.DeleteObjectAsync(_bucket, key, cancellationToken);
    }

    public async Task<bool> ExistsAsync(string key, CancellationToken cancellationToken = default)
    {
        try
        {
            await _client.GetObjectMetadataAsync(_bucket, key, cancellationToken);
            return true;
        }
        catch (AmazonS3Exception e) when (e.StatusCode == System.Net.HttpStatusCode.NotFound)
        {
            return false;
        }
    }

    // SCAFFOLD:AI_IMPLEMENTATION:START
    // Project-specific S3 operations (pre-signed URLs, multipart uploads, tagging) go here.
    // SCAFFOLD:AI_IMPLEMENTATION:END
}
