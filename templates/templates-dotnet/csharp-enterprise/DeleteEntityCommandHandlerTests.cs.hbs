namespace {{ns}}.UnitTests.Features.{{plural entity}};

public class Delete{{entity}}CommandHandlerTests
{
    private readonly Mock<{{ns}}.Application.Common.Interfaces.I{{entity}}Repository> _repository = new();
    private readonly Mock<{{ns}}.Application.Common.Interfaces.IUnitOfWork> _unitOfWork = new();

    private {{ns}}.Application.Features.{{plural entity}}.Commands.Delete{{entity}}.Delete{{entity}}CommandHandler CreateHandler() =>
        new(_repository.Object, _unitOfWork.Object);

    [Fact]
    public async Task Handle_ShouldDeleteEntity_WhenEntityExists()
    {
        // Arrange
        var entity = new {{ns}}.Domain.Entities.{{entity}} { Id = {{keyNewExpr}} };
        _repository.Setup(r => r.GetByIdAsync(entity.Id, It.IsAny<CancellationToken>())).ReturnsAsync(entity);
        var command = new {{ns}}.Application.Features.{{plural entity}}.Commands.Delete{{entity}}.Delete{{entity}}Command(entity.Id);

        // Act
        await CreateHandler().Handle(command, CancellationToken.None);

        // Assert
        // SCAFFOLD:AI_IMPLEMENTATION:START
        _repository.Verify(r => r.RemoveAsync(entity, It.IsAny<CancellationToken>()), Times.Once);
        _unitOfWork.Verify(u => u.SaveChangesAsync(It.IsAny<CancellationToken>()), Times.Once);
        // SCAFFOLD:AI_IMPLEMENTATION:END
    }

    [Fact]
    public async Task Handle_ShouldThrowNotFound_WhenEntityDoesNotExist()
    {
        // Arrange
        var command = new {{ns}}.Application.Features.{{plural entity}}.Commands.Delete{{entity}}.Delete{{entity}}Command({{keyNewExpr}});

        // Act / Assert
        // SCAFFOLD:AI_IMPLEMENTATION:START
        await Assert.ThrowsAsync<{{ns}}.Application.Common.Exceptions.NotFoundException>(() => CreateHandler().Handle(command, CancellationToken.None));
        // SCAFFOLD:AI_IMPLEMENTATION:END
