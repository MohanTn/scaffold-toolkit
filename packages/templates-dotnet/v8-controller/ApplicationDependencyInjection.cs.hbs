namespace {{ns}}.Application;

public static class DependencyInjection
{
    public static IServiceCollection AddApplication(this IServiceCollection services)
    {
        services.AddMediatR(cfg => cfg.RegisterServicesFromAssembly(typeof(DependencyInjection).Assembly));
        services.AddValidatorsFromAssembly(typeof(DependencyInjection).Assembly);
        services.AddTransient(typeof(IPipelineBehavior<,>), typeof({{ns}}.Application.Common.Behaviors.ValidationBehavior<,>));
        services.AddTransient(typeof(IPipelineBehavior<,>), typeof({{ns}}.Application.Common.Behaviors.LoggingBehavior<,>));
        // SCAFFOLD:REPOSITORIES:START
        // SCAFFOLD:REPOSITORIES:END
        return services;
    }
}
