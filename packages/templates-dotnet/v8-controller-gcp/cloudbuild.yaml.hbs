substitutions:
  _SERVICE: {{kebab (projectName)}}
  _REGION: {{options.gcp.region}}
  _IMAGE: {{options.gcp.region}}-docker.pkg.dev/{{options.gcp.projectId}}/{{kebab (projectName)}}/{{kebab (projectName)}}

steps:
  - id: build
    name: gcr.io/cloud-builders/docker
    args: ['build', '-t', '${_IMAGE}:$SHORT_SHA', '.']
  - id: push
    name: gcr.io/cloud-builders/docker
    args: ['push', '${_IMAGE}:$SHORT_SHA']
  - id: deploy
    name: gcr.io/google.com/cloudsdktool/cloud-sdk
    entrypoint: gcloud
    args:
      - run
      - deploy
      - ${_SERVICE}
      - --image=${_IMAGE}:$SHORT_SHA
      - --region=${_REGION}
      - --platform=managed
      - --project={{options.gcp.projectId}}

images:
  - ${_IMAGE}:$SHORT_SHA
