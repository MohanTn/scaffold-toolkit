  "bootstrapAnchors": [
    {
      "_comment": "DI + health-check registrations belong in the web host builder zone, in this order",
      "candidateFilenames": [
        "Program.cs"
      ],
      "anchor": {
        "kind": "after-line",
        "pattern": "\\.CreateBuilder\\s*\\("
      },
      "markers": [
        "DI",
        "HEALTH_CHECKS"
      ]
    },
    {
      "_comment": "DbSet accumulation inside this pack own DbContext class (AppDbContext accepted for older repos)",
      "candidateFilenames": [
        "ApplicationDbContext.cs",
        "AppDbContext.cs"
      ],
      "anchor": {
        "kind": "after-class-brace",
        "declarationPattern": "\\bclass\\s+(ApplicationDbContext|AppDbContext)\\b"
      },
      "markers": [
        "DBSETS"
      ]
    },
    {
      "_comment": "Repository + enterprise service registrations inside AddInfrastructure",
      "candidateFilenames": [
        "DependencyInjection.cs",
        "ApplicationServiceCollectionExtensions.cs"
      ],
      "anchor": {
        "kind": "after-class-brace",
        "declarationPattern": "\\bAddInfrastructure\\s*\\(\\s*this\\s+IServiceCollection"
